generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  type        String    @db.VarChar(50)
  subject     String    @db.VarChar(255)
  description String    @db.Text
  relatedTo   String?   @db.VarChar(100)
  dateTime    DateTime? @default(now())
}

model Approvals {
  ApprovalId  Int       @id @default(autoincrement())
  RequestType String    @db.VarChar(50)
  ReferenceId String    @db.VarChar(50)
  SubmittedBy Int
  Status      String    @default("Pending") @db.VarChar(20)
  Remarks     String?   @db.VarChar(255)
  SubmittedAt DateTime? @default(now())
  UpdatedAt   DateTime?
}

model Contacts {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  email          String    @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  company        String?   @db.VarChar(255)
  notes          String?   @db.Text
  createdAt      DateTime? @default(now())
  assignedTo     String?   @db.VarChar(255)
  title          String?   @db.VarChar(150)
  department     String?   @db.VarChar(150)
  secondaryEmail String?   @db.VarChar(255)
  mobile         String?   @db.VarChar(50)
  website        String?   @db.VarChar(255)
  leadSource     String?   @db.VarChar(100)
}

model CustomerSegments {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(100)
  region   String? @db.VarChar(100)
  industry String? @db.VarChar(100)
  interest String? @db.VarChar(100)
  dealSize String? @db.VarChar(50)
}

model Deals {
  id                Int       @id @default(autoincrement())
  dealName          String    @db.VarChar(255)
  value             Int
  stage             String    @db.VarChar(50)
  expectedCloseDate DateTime? @db.Date
  contactName       String?   @db.VarChar(255)
  company           String?   @db.VarChar(255)
  assignedTo        String?   @db.VarChar(255)
  probability       Int?
  description       String?   @db.Text
}

model FollowUps {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  type        String    @db.VarChar(50)
  description String?   @db.Text
  dueDate     DateTime?
  assignedTo  String?   @db.VarChar(100)
  contactId   Int?
  status      String?   @default("Pending") @db.VarChar(20)
  priority    String?   @db.VarChar(20)
}

model Leads {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  email          String    @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  company        String?   @db.VarChar(255)
  status         String    @db.VarChar(50)
  source         String    @db.VarChar(100)
  assignedTo     String?   @default("unassigned") @db.VarChar(100)
  lastContact    DateTime?
  value          Decimal?  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime? @default(now())
  title          String?   @db.VarChar(150)
  website        String?   @db.VarChar(255)
  industry       String?   @db.VarChar(100)
  noOfEmployees  String?   @db.VarChar(50)
  annualRevenue  String?   @db.VarChar(100)
  rating         String?   @db.VarChar(20)
  description    String?   @db.Text
}

model Quotations {
  id         Int       @id @default(autoincrement())
  clientName String    @db.VarChar(255)
  email      String    @db.VarChar(255)
  item       String    @db.VarChar(255)
  price      Decimal   @db.Decimal(10, 2)
  quantity   Int
  createdAt  DateTime? @default(now())
  assignedTo String?   @db.VarChar(255)
}

model Roles {
  id          Int    @id @default(autoincrement())
  RoleName    String @db.VarChar(50)
  Permissions String @db.Text
}

model Salesman {
  id       Int     @id @default(autoincrement())
  username String  @db.VarChar(100)
  email    String  @unique @db.VarChar(100)
  password String  @db.VarChar(255)
  Role     String? @default("Salesman") @db.VarChar(50)
}

model Users {
  UserId Int    @id @default(autoincrement())
  Role   String @db.VarChar(50)
}
